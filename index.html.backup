    </div>
  </section>

  <!-- Final CTA Section -->
  <section id="cta" class="py-24 md:py-32 relative overflow-hidden">
    <div class="hero-bg opacity-20"></div>
    <div class="grid-pattern absolute inset-0 opacity-30"></div>

    <!-- Ambient glow -->
